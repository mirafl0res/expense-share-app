DATABASE_URL=postgres://{username}:{password}@{host}:{port}/{database}
CLIENT_ORIGIN={yourClientOrigin}
AUTH0_ACTION_SECRET={yourAuth0ActionSecret}
AUTH0_CLIENT_SECRET={yourClientSecret}
AUTH0_CLIENT_ID={yourClientId}
AUTH0_ROLES_CLAIM={yourRolesClaim}
AUTH0_JWKS_URI={yourJWKSUri}
AUTH0_REDIRECT_URI={CLIENT_ORIGIN}/auth/callback
AUTH0_DOMAIN={yourDomain}
AUTH0_AUDIENCE={yourAudience}
AUTH0_SCOPES={yourScopes}
AUTH0_AUTHORIZE_URL=https://{AUTH0_DOMAIN}/authorize?response_type=code&client_id={AUTH0_CLIENT_ID}&redirect_uri={AUTH0_REDIRECT_URI}&scope={AUTH0_SCOPES}&audience={AUTH0_AUDIENCE}
AUTH0_TOKEN_URL=https://{AUTH0_DOMAIN}/oauth/token